[sqlfluff]
dialect = postgres
templater = dbt
max_line_length = 120
exclude_rules = LT05, RF04, ST06

[sqlfluff:templater:dbt]
project_dir = olist_dbt
profiles_dir = olist_dbt

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = lower
